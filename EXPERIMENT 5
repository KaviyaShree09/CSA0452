#include <stdio.h>

int main() {
    int n,i,j,bt[10],pr[10],wt[10],tat[10],p[10],t;
    float aw=0,at=0;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(i=0;i<n;i++){
        p[i]=i+1;
        printf("Enter BT and Priority for P%d: ",i+1);
        scanf("%d%d",&bt[i],&pr[i]);
    }

    for(i=0;i<n-1;i++)
        for(j=i+1;j<n;j++)
            if(pr[i]>pr[j]){
                t=pr[i]; pr[i]=pr[j]; pr[j]=t;
                t=bt[i]; bt[i]=bt[j]; bt[j]=t;
                t=p[i]; p[i]=p[j]; p[j]=t;
            }

    for(i=0;i<n;i++){
        wt[i]=(i==0)?0:wt[i-1]+bt[i-1];
        tat[i]=wt[i]+bt[i];
        aw+=wt[i]; at+=tat[i];
    }

    printf("\nP\tBT\tPR\tWT\tTAT\n");
    for(i=0;i<n;i++)
        printf("P%d\t%d\t%d\t%d\t%d\n",
               p[i],bt[i],pr[i],wt[i],tat[i]);

    printf("\nAvg WT = %.2f",aw/n);
    printf("\nAvg TAT = %.2f",at/n);

    return 0;
}
