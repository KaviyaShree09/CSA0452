#include <stdio.h>

int main() {
    int n,i,j,bt[10],wt[10],tat[10],p[10],t;
    float awt=0,atat=0;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(i=0;i<n;i++){
        p[i]=i+1;
        printf("Enter BT for P%d: ",i+1);
        scanf("%d",&bt[i]);
    }

    // Sort by burst time
    for(i=0;i<n-1;i++)
        for(j=i+1;j<n;j++)
            if(bt[i]>bt[j]){
                t=bt[i]; bt[i]=bt[j]; bt[j]=t;
                t=p[i]; p[i]=p[j]; p[j]=t;
            }

    wt[0]=0;

    for(i=0;i<n;i++){
        if(i>0) wt[i]=wt[i-1]+bt[i-1];
        tat[i]=wt[i]+bt[i];
        awt+=wt[i];
        atat+=tat[i];
    }

    printf("\nP\tBT\tWT\tTAT\n");
    for(i=0;i<n;i++)
        printf("P%d\t%d\t%d\t%d\n",p[i],bt[i],wt[i],tat[i]);

    printf("\nAvg WT = %.2f",awt/n);
    printf("\nAvg TAT = %.2f",atat/n);

    return 0;
}
