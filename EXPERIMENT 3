#include <stdio.h>

int main() {
    int n, i;
    int bt[10], wt[10], tat[10];
    float awt = 0, atat = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    // Input burst times
    for(i = 0; i < n; i++) {
        printf("Enter BT for P%d: ", i + 1);
        scanf("%d", &bt[i]);
    }

    wt[0] = 0;

    // Calculate WT and TAT
    for(i = 0; i < n; i++) {
        if(i > 0)
            wt[i] = wt[i-1] + bt[i-1];

        tat[i] = wt[i] + bt[i];

        awt += wt[i];
        atat += tat[i];
    }

    // Display result
    printf("\nP\tBT\tWT\tTAT\n");
    for(i = 0; i < n; i++) {
        printf("P%d\t%d\t%d\t%d\n",
               i+1, bt[i], wt[i], tat[i]);
    }

    printf("\nAvg WT = %.2f", awt/n);
    printf("\nAvg TAT = %.2f", atat/n);

    return 0;
}
