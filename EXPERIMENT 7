#include <stdio.h>

int main() {
    int n,bt[10],wt[10],tat[10],c[10]={0};
    int t=0,cnt=0,i,min;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    printf("Enter burst time:\n");
    for(i=0;i<n;i++)
        scanf("%d",&bt[i]);

    while(cnt<n){
        min=-1;
        for(i=0;i<n;i++)
            if(!c[i] && (min==-1 || bt[i]<bt[min]))
                min=i;

        wt[min]=t;
        t+=bt[min];
        tat[min]=wt[min]+bt[min];
        c[min]=1;
        cnt++;
    }

    printf("\nBT\tWT\tTAT\n");
    for(i=0;i<n;i++)
        printf("%d\t%d\t%d\n",bt[i],wt[i],tat[i]);

    return 0;
}
